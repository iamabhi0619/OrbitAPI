{
	"info": {
		"_postman_id": "contact-api-collection",
		"name": "Contact API - OrbitAPI",
		"description": "Complete Postman collection for Contact API endpoints. Includes public contact form submission and admin management features.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "contact-api"
	},
	"item": [
		{
			"name": "Public - Submit Contact Form",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"// Store contact ID for use in other requests",
							"if (pm.response.json().data && pm.response.json().data.id) {",
							"    pm.globals.set(\"contactId\", pm.response.json().data.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"message\": \"Hello! I'm interested in your web development services. Could you please provide more information about your pricing and availability?\",\n    \"category\": \"project-inquiry\",\n    \"priority\": \"medium\",\n    \"source\": \"website\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/contact",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact"
					]
				},
				"description": "Public endpoint for submitting contact form. No authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Get All Messages",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Response has pagination info\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.pagination).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/contact?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact"
					],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number for pagination"
						},
						{
							"key": "limit",
							"value": "10",
							"description": "Number of messages per page"
						},
						{
							"key": "status",
							"value": "open",
							"description": "Filter by status (open, in-progress, closed)",
							"disabled": true
						},
						{
							"key": "category",
							"value": "general",
							"description": "Filter by category",
							"disabled": true
						},
						{
							"key": "priority",
							"value": "high",
							"description": "Filter by priority (low, medium, high)",
							"disabled": true
						},
						{
							"key": "sortBy",
							"value": "createdAt",
							"description": "Field to sort by"
						},
						{
							"key": "sortOrder",
							"value": "desc",
							"description": "Sort order (asc, desc)"
						}
					]
				},
				"description": "Get all contact messages with filtering and pagination. Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Get Contact Summary",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has summary data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.data.totalMessages).to.exist;",
							"    pm.expect(jsonData.data.statusCounts).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/contact/summary",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"summary"
					]
				},
				"description": "Get contact statistics and summary for dashboard. Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Get Single Message",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has contact data\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.data._id).to.exist;",
							"    pm.expect(jsonData.data.name).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/contact/{{contactId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"{{contactId}}"
					]
				},
				"description": "Get a specific contact message by ID. Automatically marks as read. Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Update Message",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Message updated successfully\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.message).to.include(\"updated\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"status\": \"in-progress\",\n    \"priority\": \"high\",\n    \"feedback\": \"This is an important inquiry that needs immediate attention.\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/contact/{{contactId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"{{contactId}}"
					]
				},
				"description": "Update contact message details. Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Reply to Message",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Reply sent successfully\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.message).to.include(\"Reply sent\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"reply\": \"Thank you for your inquiry! I'd be happy to discuss your project requirements. I have availability starting next week and can provide a detailed quote based on your specific needs. Please let me know a good time to schedule a call to discuss further.\\n\\nBest regards,\\nAbhishek Kumar\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/contact/{{contactId}}/reply",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"{{contactId}}",
						"reply"
					]
				},
				"description": "Send a reply to a contact message via email. Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Mark as Read",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Message marked as read\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.data.readAt).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/contact/{{contactId}}/read",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"{{contactId}}",
						"read"
					]
				},
				"description": "Manually mark a message as read. Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Update Message Status",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Status updated successfully\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.data.status).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"status\": \"closed\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/contact/{{contactId}}/status",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"{{contactId}}",
						"status"
					]
				},
				"description": "Update the status of a contact message (open, in-progress, closed). Admin authentication required."
			},
			"response": []
		},
		{
			"name": "Admin - Delete Message",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Message deleted successfully\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"    pm.expect(jsonData.message).to.include(\"deleted\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/contact/{{contactId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"contact",
						"{{contactId}}"
					]
				},
				"description": "Delete a contact message permanently. Admin authentication required."
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set default values if not already set",
					"if (!pm.globals.get(\"baseUrl\")) {",
					"    pm.globals.set(\"baseUrl\", \"http://localhost:3000/api/v1\");",
					"}",
					"",
					"if (!pm.globals.get(\"contactId\")) {",
					"    pm.globals.set(\"contactId\", \"64f7b1c8e4b0123456789abc\");",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api/v1",
			"type": "string",
			"description": "Base URL for the API"
		},
		{
			"key": "adminToken",
			"value": "your_admin_jwt_token_here",
			"type": "string",
			"description": "Admin JWT token for authenticated requests"
		},
		{
			"key": "contactId",
			"value": "64f7b1c8e4b0123456789abc",
			"type": "string",
			"description": "Contact ID for testing (will be set automatically after creating a contact)"
		}
	]
}